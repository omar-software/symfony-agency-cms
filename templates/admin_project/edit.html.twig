{% extends 'base.html.twig' %}

{% block title %}Projekt bearbeiten{% endblock %}

{% block body %}
    {# Formular zum Bearbeiten eines vorhandenen Projekts #}

    <main class="page-wrapper">
        <section class="admin-header">
            <div>
                <h1>Projekt bearbeiten</h1>
                <p>Hier können die Projektdaten angepasst werden.</p>
            </div>

            <a href="{{ path('app_admin_projects') }}" class="button-link">Zurück</a>
        </section>

        <section class="content-section">
            <form method="post" class="admin-form">
                <div class="form-group">
                    <label for="title">Titel</label>
                    <input
                        type="text"
                        id="title"
                        name="title"
                        class="form-control"
                        value="{{ project.title }}"
                        required
                    >
                </div>

                <div class="form-group">
                    <label for="description">Beschreibung</label>
                    <textarea
                        id="description"
                        name="description"
                        class="form-control"
                        rows="5"
                        required
                    >{{ project.description }}</textarea>
                </div>

                <div class="form-group">
                    <label for="technology">Technologien</label>
                    <input
                        type="text"
                        id="technology"
                        name="technology"
                        class="form-control"
                        value="{{ project.technology }}"
                        required
                    >
                </div>

                <div class="form-group checkbox-group">
                    <label>
                        <input
                            type="checkbox"
                            name="isPublished"
                            value="1"
                            {% if project.isPublished %}checked{% endif %}
                        >
                        Projekt veröffentlichen
                    </label>
                </div>

                <button type="submit" class="button-link form-button">
                    Änderungen speichern
                </button>
            </form>
        </section>
    </main>
{% endblock %}