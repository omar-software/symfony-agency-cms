{% extends 'base.html.twig' %}

{% block title %}Admin Dashboard{% endblock %}

{% block body %}
    {# Einfaches Dashboard für den geschützten Admin-Bereich #}

    <main class="page-wrapper">
        <section class="admin-header">
            <div>
                <h1>Admin Dashboard</h1>
                <p>Willkommen im geschützten Bereich des Mini Agency CMS.</p>
            </div>

            <a href="{{ path('app_logout') }}" class="button-link">Logout</a>
        </section>

        <section class="content-section">
            <h2>Übersicht</h2>

            <div class="card-list">
                <div class="info-card">
                    <h3>Projekte gesamt</h3>
                    <p class="dashboard-number">{{ projectCount }}</p>
                </div>

                <div class="info-card">
                    <h3>Veröffentlichte Projekte</h3>
                    <p class="dashboard-number">{{ publishedProjectCount }}</p>
                </div>

                <div class="info-card">
                    <h3>Angemeldet als</h3>
                    <p>{{ app.user.userIdentifier }}</p>
                </div>
            </div>
        </section>

        <section class="content-section">
            <h2>Nächste Schritte</h2>

           <div class="info-card">
                <p>
                    Hier können Inhalte des Mini Agency CMS verwaltet werden.
                </p>

                <a href="{{ path('app_admin_projects') }}" class="button-link">
                    Projekte verwalten
                </a>

                <a href="{{ path('app_admin_messages') }}" class="button-link">
                    Kontaktanfragen ansehen
                </a>
            </div>
        </section>
    </main>
{% endblock %}